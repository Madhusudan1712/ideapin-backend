{
  "openapi": "3.0.0",
  "info": {
    "title": "ideapin API Documentation",
    "version": "1.0.0",
    "description": "API documentation for the ideapin backend service. Features user authentication powered by Supabase JWT and hierarchical note management."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local development server"
    },
    {
      "url": "https://ideapin-backend.onrender.com/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Get current user profile",
        "description": "Fetches profile info (ID and email) of the currently logged-in user parsed from the validated Supabase JWT.",
        "responses": {
          "200": {
            "description": "User profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing, invalid, or expired authentication token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/notes": {
      "get": {
        "tags": [
          "Notes"
        ],
        "summary": "Get all user notes",
        "description": "Retrieves all non-deleted notes belonging to the authenticated user.",
        "responses": {
          "200": {
            "description": "Notes retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotesListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Notes"
        ],
        "summary": "Create a note",
        "description": "Creates a new note associated with the authenticated user's ID.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateNoteInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Note created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Body validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "VALIDATION_ERROR",
                    "message": "Title is required"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/notes/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "The unique identifier of the note",
          "schema": {
            "type": "string"
          }
        }
      ],
      "put": {
        "tags": [
          "Notes"
        ],
        "summary": "Update an existing note",
        "description": "Updates details of an existing note owned by the authenticated user. Increments the note's version field.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateNoteInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Note updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing or invalid note ID, or validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "VALIDATION_ERROR",
                    "message": "Title cannot be empty"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Authenticated user does not own this note",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "FORBIDDEN",
                    "message": "You are not authorized to update this note"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Note not found or already deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "NOT_FOUND",
                    "message": "Note not found"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Notes"
        ],
        "summary": "Delete a note (soft delete)",
        "description": "Performs a soft delete by marking isDeleted = true and incrementing the note's version field.",
        "responses": {
          "200": {
            "description": "Note soft deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing or invalid note ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "VALIDATION_ERROR",
                    "message": "Note ID is required and must be a string"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Authenticated user does not own this note",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "FORBIDDEN",
                    "message": "You are not authorized to delete this note"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Note not found or already deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "NOT_FOUND",
                    "message": "Note not found"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sync": {
      "post": {
        "tags": [
          "Sync"
        ],
        "summary": "Synchronize offline changes",
        "description": "Processes a collection of local database sync operations queued offline. Supports insert, update, and delete actions.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "operations"
                ],
                "properties": {
                  "operations": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/SyncOperation"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sync operations processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "success",
                    "data",
                    "message"
                  ],
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "required": [
                        "processedCount",
                        "syncedAt"
                      ],
                      "properties": {
                        "processedCount": {
                          "type": "integer",
                          "example": 3
                        },
                        "syncedAt": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2026-06-27T10:48:28Z"
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "example": "Sync completed successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Sync validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "VALIDATION_ERROR",
                    "message": "Operations must be an array"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "UNAUTHORIZED",
                    "message": "Authorization token is missing or invalid"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INTERNAL_SERVER_ERROR",
                    "message": "Internal Server Error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter the JWT token retrieved from Supabase authentication as a Bearer token."
      }
    },
    "schemas": {
      "UserPayload": {
        "type": "object",
        "required": [
          "id",
          "email"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique Supabase user identifier (UUID)"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          }
        }
      },
      "Note": {
        "type": "object",
        "required": [
          "id",
          "userId",
          "title",
          "content",
          "isPinned",
          "visibility",
          "isDeleted",
          "version",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the note document (MongoDB ObjectId)"
          },
          "userId": {
            "type": "string",
            "description": "Associated owner user identifier"
          },
          "title": {
            "type": "string",
            "description": "Title of the note"
          },
          "content": {
            "type": "string",
            "description": "Content of the note"
          },
          "isPinned": {
            "type": "boolean",
            "description": "Indicates if the note is pinned to the dashboard"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ],
            "description": "Determines public/private accessibility of the note"
          },
          "isDeleted": {
            "type": "boolean",
            "description": "Soft deletion indicator"
          },
          "version": {
            "type": "integer",
            "description": "Incremental version count tracking schema/document updates"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Note creation date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Note last update date-time"
          }
        }
      },
      "CreateNoteInput": {
        "type": "object",
        "required": [
          "title",
          "content",
          "visibility"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Title of the note"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "description": "Detailed text content of the note"
          },
          "isPinned": {
            "type": "boolean",
            "default": false,
            "description": "Pin state for the dashboard layout"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ],
            "description": "Note access levels"
          }
        }
      },
      "UpdateNoteInput": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "New title of the note"
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "description": "New detailed text content"
          },
          "isPinned": {
            "type": "boolean",
            "description": "Toggle pin state"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "private",
              "public"
            ],
            "description": "Modify access level"
          }
        }
      },
      "SyncOperation": {
        "type": "object",
        "required": [
          "id",
          "type",
          "collection",
          "data",
          "timestamp"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique document ID mapped to the client operations list"
          },
          "type": {
            "type": "string",
            "enum": [
              "insert",
              "update",
              "delete"
            ],
            "description": "Operation type queued offline"
          },
          "collection": {
            "type": "string",
            "enum": [
              "notes"
            ],
            "description": "Database collection mapping"
          },
          "data": {
            "type": "object",
            "description": "The operation payload contents (e.g. fields matching properties of CreateNoteInput or UpdateNoteInput)"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Client timestamp of the original action"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": [
          "success",
          "data",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/UserPayload"
          },
          "message": {
            "type": "string",
            "example": "User profile retrieved successfully"
          }
        }
      },
      "NotesListResponse": {
        "type": "object",
        "required": [
          "success",
          "data",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Note"
            }
          },
          "message": {
            "type": "string",
            "example": "Notes retrieved successfully"
          }
        }
      },
      "NoteResponse": {
        "type": "object",
        "required": [
          "success",
          "data",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/Note"
          },
          "message": {
            "type": "string",
            "example": "Note action processed successfully"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "success",
          "error"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Centralized Clean Error Codes"
              },
              "message": {
                "type": "string",
                "description": "Actionable error messages"
              }
            }
          }
        }
      }
    }
  }
}
